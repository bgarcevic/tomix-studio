{
  "name": "tomix-studio",
  "displayName": "tomix studio",
  "description": "Agent friendly extension for tabular editor development in VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:tomix-studio.explorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tomix-studio",
          "title": "tomix studio",
          "icon": "assets/tomix-explorer.svg"
        }
      ]
    },
    "views": {
      "tomix-studio": [
        {
          "id": "tomix-studio.explorer",
          "name": "Tabular Model",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "tomix-studio.selectFolder",
        "title": "Select Model",
        "category": "tomix studio"
      },
      {
        "command": "tomix-studio.closeModel",
        "title": "Close Model",
        "category": "tomix studio"
      },
      {
        "command": "tomix-studio.openFileAtLine",
        "title": "Open File at Line",
        "category": "tomix studio"
      },
      {
        "command": "tomix-studio.search",
        "title": "Search Model",
        "category": "tomix studio",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tomix-studio.openFileAtLine",
          "when": "false"
        },
        {
          "command": "tomix-studio.selectFolder",
          "when": "true"
        },
        {
          "command": "tomix-studio.closeModel",
          "when": "tomix-studio.modelOpen"
        },
        {
          "command": "tomix-studio.search",
          "when": "tomix-studio.modelOpen"
        }
      ],
      "view/title": [
        {
          "command": "tomix-studio.selectFolder",
          "when": "view == 'tomix-studio.explorer'",
          "group": "navigation@1"
        },
        {
          "command": "tomix-studio.closeModel",
          "when": "view == 'tomix-studio.explorer' && tomix-studio.modelOpen",
          "group": "navigation@2"
        },
        {
          "command": "tomix-studio.search",
          "when": "view == 'tomix-studio.explorer' && tomix-studio.modelOpen",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "tomix studio",
      "properties": {
        "tomix-studio.cliPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `tx` CLI. Leave empty to resolve `tx` (or `tx.cmd` on Windows) from PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
